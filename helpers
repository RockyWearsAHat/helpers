// ---------------------------------------------------------------------------
// self-update: check the latest GitHub release and upgrade in place
// ---------------------------------------------------------------------------
const REPO_SLUG = "RockyWearsAHat/github-shell-helpers";
const UPDATE_CACHE = path.join(HOME, ".config", "helpers", "update-check.json");
const UPDATE_CHECK_TTL_MS = 24 * 60 * 60 * 1000;

// The installed version, read from the VERSION file shipped next to this CLI.
function localVersion() {
  try {
    return fs.readFileSync(path.join(REPO_DIR, "VERSION"), "utf8").trim();
  } catch {
    return "0.0.0";
  }
}

// Compare dotted numeric versions (pre-release suffix after '-' is ignored for
// ordering). Returns 1 / 0 / -1 for a>b / a==b / a<b.
function cmpVersion(a, b) {
  const parts = (v) =>
    String(v).replace(/^v/, "").split("-")[0].split(".").map((n) => parseInt(n, 10) || 0);
  const x = parts(a);
  const y = parts(b);
  for (let i = 0; i < Math.max(x.length, y.length); i++) {
    const d = (x[i] || 0) - (y[i] || 0);
    if (d !== 0) return d > 0 ? 1 : -1;
  }
  return 0;
}

// Highest published release version (without the leading "v") via the GitHub
// API; null if the network/API is unavailable. We list /releases and take the
// max rather than /releases/latest, because every release here is a 0.x
// prerelease (Beta) and /releases/latest only returns stable releases (404s).
function latestReleaseVersion() {
  const r = spawnSync(
    "curl",
    ["-fsSL", "-H", "Accept: application/vnd.github+json",
      `https://api.github.com/repos/${REPO_SLUG}/releases?per_page=30`],
    { encoding: "utf8", timeout: 15000 },
  );
  if (r.status !== 0) return null;
  try {
    const releases = JSON.parse(r.stdout);
    if (!Array.isArray(releases)) return null;
    let best = null;
    for (const rel of releases) {
      if (rel.draft || !rel.tag_name) continue;
      const v = String(rel.tag_name).replace(/^v/, "");
      if (best === null || cmpVersion(v, best) > 0) best = v;
    }
    return best;
  } catch {
    return null;
  }
}

function writeUpdateCache(latest) {
  try {
    fs.mkdirSync(path.dirname(UPDATE_CACHE), { recursive: true });
    fs.writeFileSync(UPDATE_CACHE, `${JSON.stringify({ checkedAt: Date.now(), latest }, null, 2)}\n`);
  } catch {
    /* a non-writable cache just means we re-check next time */
  }
}

function readUpdateCache() {
  try {
    return JSON.parse(fs.readFileSync(UPDATE_CACHE, "utf8"));
  } catch {
    return null;
  }
}

// Show a one-line hint when the cached check knows of a newer release, and
// refresh that cache in a detached background process when it's stale — so the
// hint stays current without ever blocking `helpers status`.
function maybeShowUpdateHint() {
  const cache = readUpdateCache();
  const current = localVersion();
  if (cache && cache.latest && cmpVersion(cache.latest, current) > 0) {
    console.log(yellow(`\n  ↑ Update available: v${current} → v${cache.latest}`) + dim(" — run `helpers update`"));
  }
  const stale = !cache || Date.now() - (cache.checkedAt || 0) > UPDATE_CHECK_TTL_MS;
  if (stale) {
    try {
      const child = require("child_process").spawn(
        process.execPath, [__filename, "update", "--check"],
        { detached: true, stdio: "ignore" },
      );
      child.unref();
    } catch {
      /* best-effort background refresh */
    }
  }
}

function cmdUpdate(args) {
  const checkOnly = args.includes("--check");
  const current = localVersion();
  const latest = latestReleaseVersion();
  if (!latest) {
    if (checkOnly) return; // silent for the background refresh path
    die("could not reach GitHub to check for updates (network?).");
  }
  writeUpdateCache(latest);
  if (cmpVersion(latest, current) <= 0) {
    if (!checkOnly) console.log(`${ok} Helpers is up to date (v${current}).`);
    return;
  }
  if (checkOnly) {
    console.log(`${yellow("↑")} Update available: v${current} → ${bold("v" + latest)}` + dim(" — run `helpers update`"));
    return;
  }
  applyUpdate(latest);
}

// Upgrade in place: fast-forward a git checkout, or download+unpack the release
// tarball for a packaged install; then rebuild the native tools and re-register.
function applyUpdate(latest) {
  console.log(`${yellow("↑")} Updating Helpers → ${bold("v" + latest)}`);
  if (fs.existsSync(path.join(REPO_DIR, ".git"))) {
    console.log(dim(`  git pull (${REPO_DIR})…`));
    const r = spawnSync("git", ["-C", REPO_DIR, "pull", "--ff-only"], { stdio: "inherit" });
    if (r.status !== 0) die("git pull failed — resolve manually, then re-run `helpers update`.");
  } else {
    const tmp = fs.mkdtempSync(path.join(os.tmpdir(), "helpers-update-"));
    const tarball = path.join(tmp, "helpers.tar.gz");
    const url = `https://github.com/${REPO_SLUG}/releases/download/v${latest}/github-shell-helpers-${latest}.tar.gz`;
    console.log(dim(`  downloading ${url}…`));
    let r = spawnSync("curl", ["-fsSL", "-o", tarball, url], { encoding: "utf8" });
    if (r.status !== 0) die(`could not download release tarball: ${url}`);
    r = spawnSync("tar", ["-xzf", tarball, "-C", tmp], { encoding: "utf8" });
    if (r.status !== 0) die("could not extract the release tarball.");
    const binRoot = path.join(tmp, `github-shell-helpers-${latest}`, "bin");
    if (!fs.existsSync(binRoot)) die("release tarball is missing its bin/ tree.");
    for (const entry of fs.readdirSync(binRoot)) {
      const dst = path.join(REPO_DIR, entry);
      try { fs.rmSync(dst, { recursive: true, force: true }); } catch {}
      fs.cpSync(path.join(binRoot, entry), dst, { recursive: true });
    }
    fs.rmSync(tmp, { recursive: true, force: true });
  }
  console.log(dim("  building native tools…"));
  buildShim();
  buildCsGrade();
  buildNative();
  console.log(dim("  re-registering with agents…"));
  cmdInstall(["--agent", "auto"]);
  writeUpdateCache(localVersion());
  console.log(green(bold(`\nUpdated to v${localVersion()}.`)) + dim(" Restart your agent (or /mcp reconnect) to load the new tools."));
}

function cmdDoctor() {
  console.log(bold("\nHelpers doctor\n"));
  let problems = 0;
  const check = (label, pass, hint) => {
    console.log(`  ${pass ? ok : no} ${label}`);
    if (!pass && hint) { console.log(dim(`      → ${hint}`)); problems++; }
  };
  check("node available", true);
  check("MCP server file present", fs.existsSync(SERVER_PATH), `expected at ${SERVER_PATH}`);

  // Toolchain preflight — surface missing build prerequisites up front with
  // copy-pasteable, per-OS install commands, instead of discovering them one
  // failed build at a time.
  const isWin = process.platform === "win32";
  const cargo = findCargo();
  check(
    "Rust toolchain (cargo) — REQUIRED for the native tools",
    Boolean(cargo),
    isWin
      ? "Install Rust: https://rustup.rs (winget install Rustlang.Rustup), then `helpers build`."
      : "Install Rust: https://rustup.rs (or: brew install rust), then `helpers build`.",
  );
  check(
    "C compiler (cc/clang/gcc) — optional fast launcher",
    Boolean(findCC()),
    isWin
      ? "Install MinGW-w64 (e.g. WinLibs) and add its bin/ to PATH. Without it the server still runs via node (cold start)."
      : "Install Xcode CLT (xcode-select --install) or gcc. Without it the server still runs via node (cold start).",
  );
  if (isWin && cargo) {
    // The GNU Rust host links windows-sys via dlltool; the MSVC host does not.
    const host = (spawnSync("rustc", ["-vV"], { encoding: "utf8" }).stdout || "");
    if (/host:\s*\S*gnu/i.test(host)) {
      check(
        "dlltool (MinGW-w64) — required for the GNU Rust host",
        has("dlltool"),
        "Install MinGW-w64 (WinLibs) and add its bin/ to PATH, or switch host: rustup default stable-x86_64-pc-windows-msvc",
      );
    }
  }
  // doctor is a health probe: actually boot the MCP server here (the fast native
  // path that `helpers status` uses would not prove the server starts).
  const all = listAllToolsViaServer();
  check(`MCP server starts and lists tools (${all.length})`, all.length > 0, "check `node " + SERVER_PATH + "` for load errors");
  check("tools.json present", fs.existsSync(TOOLS_CONFIG_PATH), "run `helpers enable` to create it");
  check("fast C launcher compiled", fs.existsSync(SHIM_BIN), "run `helpers build` (needs a C compiler); optional — falls back to node");
  {
    // git-cs-grade is "native" when the installed command is the compiled
    // binary (Mach-O/ELF) rather than the Node script (starts with a shebang).
    let native = false;
    try { native = !fs.readFileSync(CS_GRADE_CMD).slice(0, 2).equals(Buffer.from("#!")); } catch {}
    check("git-cs-grade native (Rust) build", native, "run `helpers build` (needs cargo: https://rustup.rs); optional — falls back to node");
  }
  {
    // helpers-native is REQUIRED — the MCP tools it hosts have no Node fallback.
    let nativeTools = 0;
    if (fs.existsSync(HELPERS_NATIVE_CMD)) {
      const r = spawnSync(HELPERS_NATIVE_CMD, ["schemas"], { encoding: "utf8" });
      try { nativeTools = JSON.parse(r.stdout).length; } catch {}
    }
    check(
      `helpers-native MCP tools built (${nativeTools})`,
      nativeTools > 0,
      "REQUIRED (no Node fallback) — install Rust (https://rustup.rs), then run `helpers build`.",
    );
  }
  if (fs.existsSync(SHIM_BIN)) {
    const r = spawnSync("pgrep", ["-f", "helpers-serverd"], { encoding: "utf8" });
    const up = (r.stdout || "").trim().length > 0;
    console.log(`  ${dim("·")} background server ${up ? "running" : "idle (starts automatically on use)"}`);
  }
  const reg = claudeMcpRegistered();
  if (reg !== null) check("helpers registered with Claude Code", reg, "run `helpers install --agent claude`");
  check("claude-config bundled", fs.existsSync(CLAUDE_CONFIG_SRC), "reinstall Helpers source");
  console.log(problems === 0 ? green("\n  All checks passed.\n") : yellow(`\n  ${problems} issue(s) found.\n`));
}

// ---------------------------------------------------------------------------
