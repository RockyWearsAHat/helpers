#!/usr/bin/env node
"use strict";

/*
 * helpers — unified control surface for Helpers.
 *
 * One command to install Helpers into any AI agent (Claude Code, GitHub Copilot),
 * toggle the whole tool surface on/off, enable/disable individual tools, check
 * health, and grade a CS project toward an A+.
 *
 * Helpers is agent-agnostic: the tools ship as a standard stdio MCP server, so any
 * MCP-capable agent can use them. This CLI handles the per-agent wiring.
 *
 * Tool state lives in ~/.config/helpers-server/tools.json and is re-read
 * by the running MCP server on every request, so every toggle here takes effect
 * live — no agent restart required.
 */

const fs = require("fs");
const path = require("path");
const os = require("os");
const { spawnSync } = require("child_process");

const HOME = process.env.HOME || process.env.USERPROFILE || os.homedir();
const REPO_DIR = fs.realpathSync(path.dirname(fs.realpathSync(__filename)));
const SERVER_PATH = path.join(REPO_DIR, "helpers-server");
const DAEMON_PATH = path.join(REPO_DIR, "helpers-serverd.js");
const SHIM_SRC = path.join(REPO_DIR, "helpers-mcp.c");
const SHIM_BIN = path.join(REPO_DIR, "helpers-mcp");
// Native Rust git-cs-grade: crate dir, its release artifact, the installed
// command, and the Node implementation used as a graceful fallback.
// Windows cargo emits `.exe` binaries; every native artifact/command path must
// account for that suffix or the loader/built-detection misses the binary.
const EXE = process.platform === "win32" ? ".exe" : "";
const CS_GRADE_CRATE = path.join(REPO_DIR, "cs-grade");
const CS_GRADE_ARTIFACT = path.join(CS_GRADE_CRATE, "target", "release", `git-cs-grade${EXE}`);
const CS_GRADE_CMD = path.join(REPO_DIR, "git-cs-grade");
const CS_GRADE_JS = path.join(REPO_DIR, "git-cs-grade.js");
// Native Rust MCP tools (helpers-native): the crate dir, its release artifact, and
// the installed binary the MCP daemon shells out to. Unlike git-cs-grade there
// is NO Node fallback — these tools are Rust-only, so a missing/broken build is
// a hard error the user must fix (install Rust, then `helpers build`).
const HELPERS_NATIVE_CRATE = path.join(REPO_DIR, "native");
const HELPERS_NATIVE_ARTIFACT = path.join(HELPERS_NATIVE_CRATE, "target", "release", `helpers-native${EXE}`);
// The installed binary the MCP daemon shells out to. HELPERS_NATIVE_BIN overrides
// it (matching lib/mcp-native.js so the CLI and the server agree); otherwise it is
// the `.exe`-aware repo-root path. Without this, Windows built-detection looked for
// a suffix-less `helpers-native` and reported "not built" despite a working .exe.
const HELPERS_NATIVE_CMD = process.env.HELPERS_NATIVE_BIN || path.join(REPO_DIR, `helpers-native${EXE}`);
// Standalone git-* CLIs ported to Rust: symlinked to the one helpers-native binary,
// which dispatches busybox-style on argv[0]. Keep in sync with gitcli::CLI_NAMES.
const GITCLI_NAMES = [
  "git-resolve",
  "git-remerge",
  "git-fucked-the-push",
  "git-initialize",
  "git-get",
  "git-scan-for-leaked-envs",
  "git-upload",
  "git-checkpoint",
  "git-help-i-pushed-an-env",
];
const TOOLS_CONFIG_DIR = path.join(HOME, ".config", "helpers-server");
const TOOLS_CONFIG_PATH = path.join(TOOLS_CONFIG_DIR, "tools.json");
const CLAUDE_DIR = path.join(HOME, ".claude");
const COPILOT_DIR = path.join(HOME, ".copilot");
const CLAUDE_CONFIG_SRC = path.join(REPO_DIR, "claude-config");
const COPILOT_CONFIG_SRC = path.join(REPO_DIR, "copilot-config");

// ---------------------------------------------------------------------------
// tiny ANSI helpers (auto-disabled when not a TTY or NO_COLOR is set)
// ---------------------------------------------------------------------------
const color = process.stdout.isTTY && !process.env.NO_COLOR;
const c = (n, s) => (color ? `\x1b[${n}m${s}\x1b[0m` : s);
const bold = (s) => c("1", s);
const green = (s) => c("32", s);
const red = (s) => c("31", s);
const yellow = (s) => c("33", s);
const dim = (s) => c("2", s);
const ok = green("✓");
const no = red("✗");

function die(msg, code = 1) {
  process.stderr.write(`${red("helpers:")} ${msg}\n`);
  process.exit(code);
}

// ---------------------------------------------------------------------------
// tools.json read/write
// ---------------------------------------------------------------------------
function readConfig() {
  try {
    return JSON.parse(fs.readFileSync(TOOLS_CONFIG_PATH, "utf8"));
  } catch {
    return {};
  }
}

function writeConfig(cfg) {
  fs.mkdirSync(TOOLS_CONFIG_DIR, { recursive: true });
  // Normalize shape so the file stays clean and predictable.
  const out = {
    disabled: cfg.disabled === true,
    disabledTools: Array.from(new Set(cfg.disabledTools || [])).sort(),
  };
  fs.writeFileSync(TOOLS_CONFIG_PATH, `${JSON.stringify(out, null, 2)}\n`);
  return out;
}

// ---------------------------------------------------------------------------
// the full universe of tool names (native Rust tools + Node web-research tools)
// ---------------------------------------------------------------------------
// Node-only tools the MCP server adds on top of the native binary. Sourced from
// the same module the server uses so this list can't drift; the literal names
// are the fallback if that module can't be loaded.
function researchToolNames() {
  if (process.env.HELPERS_MCP_DISABLE_RESEARCH) return [];
  try {
    return require("./lib/mcp-research-tools").RESEARCH_TOOLS.map((t) => t.name);
  } catch {
    return ["search_web", "scrape_webpage"];
  }
}

// Fast path: ask the native binary for its schemas (~10ms) and add the Node
// tools. This mirrors the server's getAllTools() without paying a node MCP
// server cold start. Falls back to the server only if the binary is unusable.
function listAllTools() {
  const res = spawnSync(HELPERS_NATIVE_CMD, ["schemas"], {
    encoding: "utf8",
    timeout: 10000,
  });
  if (res.status === 0) {
    try {
      const native = JSON.parse(res.stdout).map((t) => t.name);
      return [...native, ...researchToolNames()].sort();
    } catch {
      /* malformed output — fall through to the server path */
    }
  }
  return listAllToolsViaServer();
}

// Fallback: drive the MCP server over stdio. Slower (node cold start) and only
// used when the native binary is missing or broken.
function listAllToolsViaServer() {
  const req =
    JSON.stringify({
      jsonrpc: "2.0",
      id: 1,
      method: "initialize",
      params: {},
    }) +
    "\n" +
    JSON.stringify({ jsonrpc: "2.0", id: 2, method: "tools/list" }) +
    "\n";
  const res = spawnSync(process.execPath, [SERVER_PATH], {
    input: req,
    encoding: "utf8",
    timeout: 20000,
    env: { ...process.env, HELPERS_FORCE_ENABLE: "1" },
  });
  const names = [];
  for (const line of (res.stdout || "").split("\n")) {
    if (!line.trim()) continue;
    let msg;
    try {
      msg = JSON.parse(line);
    } catch {
      continue;
    }
    if (msg.id === 2 && msg.result && Array.isArray(msg.result.tools)) {
      for (const t of msg.result.tools) names.push(t.name);
    }
  }
  return names.sort();
}

// ---------------------------------------------------------------------------
// agent detection
// ---------------------------------------------------------------------------
function has(cmd) {
  const r = spawnSync(process.platform === "win32" ? "where" : "command",
    process.platform === "win32" ? [cmd] : ["-v", cmd],
    { encoding: "utf8", shell: process.platform !== "win32" });
  return r.status === 0;
}

function detectAgents() {
  const agents = [];
  if (has("claude") || fs.existsSync(CLAUDE_DIR)) agents.push("claude");
  if (fs.existsSync(COPILOT_DIR) || has("code")) agents.push("copilot");
  return agents;
}

// ---------------------------------------------------------------------------
// recursive copy (no deps)
// ---------------------------------------------------------------------------
function copyTree(src, dest) {
  const stat = fs.statSync(src);
  if (stat.isDirectory()) {
    fs.mkdirSync(dest, { recursive: true });
    for (const entry of fs.readdirSync(src)) {
      copyTree(path.join(src, entry), path.join(dest, entry));
    }
  } else {
    fs.mkdirSync(path.dirname(dest), { recursive: true });
    fs.copyFileSync(src, dest);
  }
}

// Write a managed block (delimited) into a file without clobbering user content.
const BLOCK_START = "<!-- Helpers:BEGIN (managed by `helpers install`; do not edit) -->";
const BLOCK_END = "<!-- Helpers:END -->";
function writeManagedBlock(file, body) {
  let existing = "";
  try {
    existing = fs.readFileSync(file, "utf8");
  } catch {}
  const block = `${BLOCK_START}\n${body}\n${BLOCK_END}`;
  const re = new RegExp(
    `${BLOCK_START.replace(/[.*+?^${}()|[\]\\]/g, "\\$&")}[\\s\\S]*?${BLOCK_END.replace(/[.*+?^${}()|[\]\\]/g, "\\$&")}`,
  );
  let next;
  if (re.test(existing)) {
    next = existing.replace(re, block);
  } else {
    next = existing.trim() ? `${existing.trimEnd()}\n\n${block}\n` : `${block}\n`;
  }
  fs.mkdirSync(path.dirname(file), { recursive: true });
  fs.writeFileSync(file, next);
}

function removeManagedBlock(file) {
  let existing;
  try {
    existing = fs.readFileSync(file, "utf8");
  } catch {
    return;
  }
  const re = new RegExp(
    `\\n*${BLOCK_START.replace(/[.*+?^${}()|[\]\\]/g, "\\$&")}[\\s\\S]*?${BLOCK_END.replace(/[.*+?^${}()|[\]\\]/g, "\\$&")}\\n*`,
  );
  fs.writeFileSync(file, existing.replace(re, "\n"));
}

// ---------------------------------------------------------------------------
// fast C shim: compile helpers-mcp so cold node startup is paid once (warm daemon)
// ---------------------------------------------------------------------------
function findCC() {
  for (const cc of [process.env.CC, "cc", "clang", "gcc"].filter(Boolean)) {
    if (has(cc)) return cc;
  }
  return null;
}

// Returns the path to the runnable MCP command + args the agent should launch.
// Prefers the compiled C shim (warm daemon, ~0 startup); falls back to node.
function buildShim({ quiet } = {}) {
  if (!fs.existsSync(SHIM_SRC)) return null;
  const cc = findCC();
  if (!cc) {
    if (!quiet) console.log(`  ${yellow("!")} no C compiler found — using direct node (still works, just cold start each session)`);
    return null;
  }
  const node = process.execPath;
  const r = spawnSync(
    cc,
    [
      "-O2", "-Wall",
      `-DNODE_BIN="${node}"`,
      `-DDAEMON_JS="${DAEMON_PATH}"`,
      `-DSTDIO_JS="${SERVER_PATH}"`,
      "-o", SHIM_BIN, SHIM_SRC,
    ],
    { encoding: "utf8" },
  );
  if (r.status !== 0) {
    if (!quiet) console.log(`  ${no} shim compile failed: ${(r.stderr || "").trim().split("\n")[0]}`);
    return null;
  }
  try { fs.chmodSync(SHIM_BIN, 0o755); } catch {}
  if (!quiet) console.log(`  ${ok} compiled fast C launcher (helpers-mcp) — fast startup, auto-managed background server`);
  return SHIM_BIN;
}

// The command+args to register with an agent for the MCP server.
function mcpLaunch() {
  if (fs.existsSync(SHIM_BIN)) return { cmd: SHIM_BIN, args: [] };
  return { cmd: process.execPath, args: [SERVER_PATH] };
}

// ---------------------------------------------------------------------------
// native git-cs-grade: compile the Rust crate so grading starts in ~1ms and
// runs several times faster, falling back to the Node implementation when no
// Rust toolchain (cargo) is available.
// ---------------------------------------------------------------------------
function findCargo() {
  for (const c of [process.env.CARGO, "cargo"].filter(Boolean)) {
    if (has(c)) return c;
  }
  return null;
}

// Install the Node implementation as the `git-cs-grade` command (the fallback).
function installCsGradeFallback() {
  if (!fs.existsSync(CS_GRADE_JS)) return false;
  try {
    fs.copyFileSync(CS_GRADE_JS, CS_GRADE_CMD);
    fs.chmodSync(CS_GRADE_CMD, 0o755);
    return true;
  } catch {
    return false;
  }
}

// Compile cs-grade to a native binary and install it as `git-cs-grade`.
// Returns the command path on success (native or Node fallback), else null.
function buildCsGrade({ quiet } = {}) {
  if (!fs.existsSync(CS_GRADE_CRATE)) return null;
  const cargo = findCargo();
  if (!cargo) {
    const used = installCsGradeFallback();
    if (!quiet) {
      console.log(`  ${yellow("!")} no Rust toolchain (cargo) found — using the Node git-cs-grade${used ? "" : " (missing!)"}.`);
      console.log(dim("      Install Rust for the fast native build: https://rustup.rs  (or: brew install rust), then run `helpers build`."));
    }
    return used ? CS_GRADE_CMD : null;
  }
  const r = spawnSync(cargo, ["build", "--release"], { cwd: CS_GRADE_CRATE, encoding: "utf8" });
  if (r.status !== 0 || !fs.existsSync(CS_GRADE_ARTIFACT)) {
    const used = installCsGradeFallback();
    if (!quiet) {
      console.log(`  ${no} git-cs-grade build failed: ${(r.stderr || "").trim().split("\n").pop() || "unknown error"}`);
      console.log(dim(`      Falling back to the Node implementation${used ? "" : " (also missing!)"}. Fix the build, then run \`helpers build\`.`));
    }
    return used ? CS_GRADE_CMD : null;
  }
  try {
    fs.copyFileSync(CS_GRADE_ARTIFACT, CS_GRADE_CMD);
    fs.chmodSync(CS_GRADE_CMD, 0o755);
  } catch (e) {
    if (!quiet) console.log(`  ${no} could not install git-cs-grade: ${e.message}`);
    return null;
  }
  if (!quiet) console.log(`  ${ok} compiled native git-cs-grade (Rust) — ~1ms startup, faster scans`);
  return CS_GRADE_CMD;
}

// Compile the native MCP tool binary (helpers-native) and install it at the repo
// root. These tools are Rust-only — there is no Node fallback — so any failure
// is reported as a hard error and sets a non-zero exit code, making `helpers build`
// and `helpers install` fail loudly so the user can fix the toolchain.
function buildNative({ quiet } = {}) {
  const fail = (msg, hint) => {
    console.log(`  ${no} ${msg}`);
    if (hint) console.log(dim(`      ${hint}`));
    process.exitCode = 1;
    return false;
  };
  if (!fs.existsSync(HELPERS_NATIVE_CRATE)) {
    return fail(`native tool crate missing at ${HELPERS_NATIVE_CRATE}`, "Reinstall the Helpers source — the `native/` crate is required.");
  }
  const cargo = findCargo();
  if (!cargo) {
    return fail(
      "no Rust toolchain (cargo) found — the native MCP tools cannot be built.",
      "Install Rust: https://rustup.rs  (or: brew install rust), then run `helpers build`. These tools are required; there is no Node fallback.",
    );
  }
  const r = spawnSync(cargo, ["build", "--release"], { cwd: HELPERS_NATIVE_CRATE, encoding: "utf8" });
  if (r.status !== 0 || !fs.existsSync(HELPERS_NATIVE_ARTIFACT)) {
    return fail(
      `helpers-native build failed: ${(r.stderr || "").trim().split("\n").pop() || "unknown error"}`,
      "Fix the Rust build error above, then run `helpers build`.",
    );
  }
  try {
    fs.copyFileSync(HELPERS_NATIVE_ARTIFACT, HELPERS_NATIVE_CMD);
    fs.chmodSync(HELPERS_NATIVE_CMD, 0o755);
  } catch (e) {
    return fail(`could not install helpers-native: ${e.message}`, `Check write permissions on ${REPO_DIR}.`);
  }
  // The native MCP tools are the success criterion, so probe them (valid JSON,
  // tool count > 0) BEFORE the optional git-* symlinks — that way a filesystem
  // limitation on the symlinks (e.g. Windows requires elevation to create them)
  // can never fail an otherwise-working install. A broken binary is still caught
  // here at build time rather than on the agent's first tool call.
  const probe = spawnSync(HELPERS_NATIVE_CMD, ["schemas"], { encoding: "utf8" });
  let toolCount = 0;
  try { toolCount = JSON.parse(probe.stdout).length; } catch {}
  if (probe.status !== 0 || toolCount === 0) {
    return fail("helpers-native built but did not report any tools.", "Run `" + HELPERS_NATIVE_CMD + " schemas` to see the error.");
  }
  // Best-effort: symlink each ported git-* CLI to the one binary (busybox-style
  // dispatch on argv[0]). Non-fatal — these are standalone conveniences, not part
  // of the MCP tool surface; on Windows symlinks need elevation, so a failure just
  // means the git-* shortcuts are unavailable while the MCP tools work fine.
  let linkFailures = 0;
  for (const name of GITCLI_NAMES) {
    const link = path.join(REPO_DIR, name);
    try {
      if (fs.existsSync(link) || fs.lstatSync(link, { throwIfNoEntry: false })) fs.rmSync(link, { force: true });
    } catch {}
    try {
      fs.symlinkSync(`helpers-native${EXE}`, link);
    } catch {
      linkFailures++;
    }
  }
  if (linkFailures > 0 && !quiet) {
    console.log(dim(`      (${linkFailures}/${GITCLI_NAMES.length} git-* CLI shims not linked — optional; MCP tools unaffected)`));
  }
  if (!quiet) console.log(`  ${ok} compiled native MCP tools (helpers-native, Rust) — ${toolCount} tool(s), ~1ms startup`);
  return true;
}

function listDaemons() {
  const dir = path.join(HOME, ".cache", "helpers");
  try {
    return fs.readdirSync(dir).filter((f) => /^mcpd-.*\.sock$/.test(f)).map((f) => path.join(dir, f));
  } catch {
    return [];
  }
}

function cmdDaemon(args) {
  const sub = args[0] || "status";
  if (sub === "status") {
    const socks = listDaemons();
    const r = spawnSync("pgrep", ["-f", "helpers-serverd"], { encoding: "utf8" });
    const pids = (r.stdout || "").trim().split("\n").filter(Boolean);
    console.log(bold("\nHelpers background server"));
    console.log(`  running:  ${pids.length ? green(pids.join(", ")) : dim("idle (starts automatically on next use)")}`);
    console.log(`  sockets:  ${socks.length || dim("0")}`);
    socks.forEach((s) => console.log(dim(`    ${s}`)));
    console.log(dim("\n  Managed automatically: starts on demand, exits after ~15 min idle.\n"));
    return;
  }
  if (sub === "stop" || sub === "restart") {
    spawnSync("pkill", ["-f", "helpers-serverd"], { stdio: "ignore" });
    for (const s of listDaemons()) { try { fs.unlinkSync(s); } catch {} }
    console.log(`${ok} Stopped the background server${sub === "restart" ? " (restarts automatically on next use)" : ""}.`);
    console.log(dim("Use this after changing Helpers code so the next launch picks it up."));
    return;
  }
  die(`unknown 'helpers daemon' subcommand: ${sub} (use status|stop|restart)`);
}

// ---------------------------------------------------------------------------
// install: Claude Code
// ---------------------------------------------------------------------------
// Tell any running warm daemon(s) that the tool set changed, so agents already
// connected (this very session included) refresh their tools live — no restart.
// Best-effort: pings every per-workspace daemon socket; the daemon rebroadcasts
// notifications/tools/list_changed to its MCP clients, which re-fetch tools/list.
function signalReload() {
  const net = require("net");
  const sockDir = path.join(HOME, ".cache", "helpers");
  let socks;
  try {
    socks = fs.readdirSync(sockDir).filter((f) => f.startsWith("mcpd-") && f.endsWith(".sock"));
  } catch {
    return; // no daemon dir => nothing connected
  }
  for (const f of socks) {
    try {
      const c = net.connect(path.join(sockDir, f));
      c.on("connect", () => {
        c.write(`${JSON.stringify({ jsonrpc: "2.0", method: "$/helpers/reload" })}\n`);
        c.end();
      });
      c.on("error", () => {}); // stale/closed socket — ignore
    } catch {}
  }
}

// Remove pre-rebrand (GSH / Git Shell Helpers) agent-config artifacts so an
// upgraded install doesn't keep stale, conflicting instructions/skills/commands
// next to the current Helpers ones.
function pruneLegacyAgentConfig() {
  const legacy = [
    path.join(CLAUDE_DIR, "commands", "gsh.md"),
    path.join(CLAUDE_DIR, "skills", "gsh"),
    path.join(COPILOT_DIR, "instructions", "gsh-routing-index.instructions.md"),
    path.join(COPILOT_DIR, "instructions", "gsh-mcp-tools.instructions.md"),
    path.join(COPILOT_DIR, "skills", "gsh"),
  ];
  let removed = 0;
  for (const p of legacy) {
    try {
      // lstat (not exists) so dangling symlinks from old installs are caught;
      // unlink removes a symlink without following it (rmSync+force would treat
      // a broken link's ENOENT as "already gone" and leave it behind).
      const st = fs.lstatSync(p, { throwIfNoEntry: false });
      if (!st) continue;
      if (st.isDirectory()) fs.rmSync(p, { recursive: true, force: true });
      else fs.unlinkSync(p);
      removed++;
    } catch {}
  }
  if (removed) console.log(dim(`  Removed ${removed} legacy GSH config file(s).`));
}

function installClaude(force) {
  console.log(bold("\n→ Installing Helpers for Claude Code"));

  // 0. Build the fast C shim (warm daemon) and native git-cs-grade — each
  //    falls back to Node when its toolchain is unavailable.
  buildShim();
  buildCsGrade();
  buildNative();
  const { cmd, args } = mcpLaunch();

  // 1. Register the MCP server (user scope) — idempotent.
  if (has("claude")) {
    spawnSync("claude", ["mcp", "remove", "-s", "user", "helpers"], {
      stdio: "ignore",
    });
    const add = spawnSync(
      "claude",
      ["mcp", "add", "-s", "user", "helpers", "--", cmd, ...args],
      { encoding: "utf8" },
    );
    if (add.status === 0) {
      console.log(`  ${ok} MCP server 'helpers' registered (user scope) via ${cmd === SHIM_BIN ? "fast C shim" : "node"}`);
    } else {
      console.log(`  ${no} MCP registration failed: ${(add.stderr || "").trim()}`);
    }
  } else {
    console.log(`  ${yellow("!")} 'claude' CLI not found — add MCP manually:`);
    console.log(dim(`      claude mcp add -s user helpers -- ${cmd} ${args.join(" ")}`));
  }

  // 2. CLAUDE.md managed block (always-on core behavior).
  const coreFile = path.join(CLAUDE_CONFIG_SRC, "CLAUDE.helpers.md");
  if (fs.existsSync(coreFile)) {
    writeManagedBlock(path.join(CLAUDE_DIR, "CLAUDE.md"), fs.readFileSync(coreFile, "utf8").trim());
    console.log(`  ${ok} Helpers core written to ~/.claude/CLAUDE.md (managed block)`);
  }

  // 3. Skills, commands, agents.
  for (const kind of ["skills", "commands", "agents"]) {
    const src = path.join(CLAUDE_CONFIG_SRC, kind);
    if (!fs.existsSync(src)) continue;
    const dest = path.join(CLAUDE_DIR, kind);
    for (const entry of fs.readdirSync(src)) {
      copyTree(path.join(src, entry), path.join(dest, entry));
    }
    console.log(`  ${ok} ${kind} installed to ~/.claude/${kind}/`);
  }
  console.log(dim("  Restart Claude Code (or /mcp reconnect) to pick up the helpers server."));
}

// ---------------------------------------------------------------------------
// install: GitHub Copilot — copy the copilot-config bundle to ~/.copilot
// ---------------------------------------------------------------------------
function installCopilot(force) {
  console.log(bold("\n→ Installing Helpers for GitHub Copilot"));
  if (!fs.existsSync(COPILOT_CONFIG_SRC)) {
    console.log(`  ${no} copilot-config bundle not found in ${REPO_DIR}`);
    return;
  }
  // Helpers MCP tools surface in Copilot via the helpers MCP server (VS Code mcp.json /
  // the bundled extension). Here we install the agent-guidance bundle only.
  for (const kind of ["instructions", "agents", "skills"]) {
    const src = path.join(COPILOT_CONFIG_SRC, kind);
    if (!fs.existsSync(src)) continue;
    const dest = path.join(COPILOT_DIR, kind);
    for (const entry of fs.readdirSync(src)) {
      // Always refresh the bundled guidance so instruction/skill updates land on
      // reinstall (matches the Claude side, which overwrites).
      copyTree(path.join(src, entry), path.join(dest, entry));
    }
    console.log(`  ${ok} ${kind} installed to ~/.copilot/${kind}/`);
  }
  console.log(dim("  Reload VS Code (or restart Copilot) to pick up the helpers server and guidance."));
}

function cmdInstall(args) {
  let agent = "auto";
  let force = false;
  for (let i = 0; i < args.length; i++) {
    if (args[i] === "--agent") agent = args[++i];
    else if (args[i] === "--force") force = true;
  }
  let targets;
  if (agent === "all") targets = ["claude", "copilot"];
  else if (agent === "auto") {
    targets = detectAgents();
    if (targets.length === 0) {
      die("no AI agent detected. Use --agent claude|copilot|all to force.");
    }
    console.log(dim(`Detected: ${targets.join(", ")}`));
  } else targets = [agent];

  pruneLegacyAgentConfig();
  for (const t of targets) {
    if (t === "claude") installClaude(force);
    else if (t === "copilot") installCopilot(force);
    else die(`unknown agent '${t}'`);
  }
  // Ensure tools.json exists in a known-good state.
  if (!fs.existsSync(TOOLS_CONFIG_PATH)) writeConfig(readConfig());
  // Nudge any live daemon so already-connected agents pick up the new tools
  // without a session restart.
  signalReload();
  console.log(green(bold("\nHelpers installed.")) + dim(" Run `helpers status` to verify.") + dim(" Connected agents refresh automatically."));
}

function cmdUninstall(args) {
  let agent = args[0] === "--agent" ? args[1] : "claude";
  if (agent === "claude" || agent === "all") {
    if (has("claude")) spawnSync("claude", ["mcp", "remove", "-s", "user", "helpers"], { stdio: "ignore" });
    removeManagedBlock(path.join(CLAUDE_DIR, "CLAUDE.md"));
    console.log(`${ok} Removed helpers MCP server and CLAUDE.md block (skills/commands/agents left in place).`);
  }
  if (agent === "copilot" || agent === "all") {
    console.log(dim("Copilot config left in place; remove ~/.copilot/{agents,instructions,skills} manually if desired."));
  }
}

// ---------------------------------------------------------------------------
// enable / disable / bypass (master switch)
// ---------------------------------------------------------------------------
function setMaster(disabled) {
  const cfg = readConfig();
  cfg.disabled = disabled;
  writeConfig(cfg);
  if (disabled) console.log(`${ok} Helpers ${bold("disabled")} (bypassed). All Helpers tools hidden. Re-enable: ${bold("helpers enable")}`);
  else console.log(`${ok} Helpers ${bold("enabled")}. Tool surface active.`);
  console.log(dim("Takes effect live — no agent restart needed."));
}

function cmdBypass(args) {
  const arg = (args[0] || "").toLowerCase();
  if (arg === "on") return setMaster(true);
  if (arg === "off") return setMaster(false);
  // toggle
  return setMaster(!readConfig().disabled);
}

// ---------------------------------------------------------------------------
// tool subcommands
// ---------------------------------------------------------------------------
function cmdTool(args) {
  const sub = args[0];
  const cfg = readConfig();
  const disabledSet = new Set(cfg.disabledTools || []);

  if (!sub || sub === "list") {
    const all = listAllTools();
    if (all.length === 0) {
      console.log(yellow("No tools reported by the MCP server (load error?). Run `helpers doctor`."));
      return;
    }
    console.log(bold(`\nHelpers tools (${all.length})  ${cfg.disabled ? red("[MASTER: DISABLED]") : green("[MASTER: ENABLED]")}\n`));
    for (const name of all) {
      const off = disabledSet.has(name) || cfg.disabled;
      console.log(`  ${off ? no : ok} ${off ? dim(name) : name}`);
    }
    console.log(dim(`\nToggle: helpers tool disable <name> | helpers tool enable <name> | helpers tool enable all`));
    return;
  }

  if (sub === "enable" || sub === "disable") {
    const target = args[1];
    if (!target) die(`usage: helpers tool ${sub} <name|all>`);
    const all = listAllTools();
    if (target === "all") {
      cfg.disabledTools = sub === "disable" ? all.slice() : [];
      writeConfig(cfg);
      console.log(`${ok} ${sub === "disable" ? "Disabled" : "Enabled"} all ${all.length} tools.`);
      return;
    }
    if (all.length && !all.includes(target)) {
      console.log(yellow(`Warning: '${target}' is not a known Helpers tool. Known: ${all.join(", ")}`));
    }
    if (sub === "disable") disabledSet.add(target);
    else disabledSet.delete(target);
    cfg.disabledTools = Array.from(disabledSet);
    writeConfig(cfg);
    console.log(`${ok} Tool '${target}' ${sub === "disable" ? "disabled" : "enabled"}.`);
    console.log(dim("Takes effect live."));
    return;
  }

  if (sub === "reset") {
    cfg.disabledTools = [];
    writeConfig(cfg);
    console.log(`${ok} Cleared per-tool disables.`);
    return;
  }

  die(`unknown 'helpers tool' subcommand: ${sub}`);
}

