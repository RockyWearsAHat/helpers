// ---------------------------------------------------------------------------
// index: cheap project map (delegates to the native helpers-native binary)
// ---------------------------------------------------------------------------
function projectRoot() {
  const top = spawnSync("git", ["rev-parse", "--show-toplevel"], {
    encoding: "utf8",
  });
  return top.status === 0 ? top.stdout.trim() : process.cwd();
}

function cmdIndex(args) {
  if (!fs.existsSync(HELPERS_NATIVE_CMD)) {
    die("helpers-native is not built — run `helpers build` (needs Rust: https://rustup.rs).");
  }
  const root = projectRoot();
  const sub = args[0] || "build";

  // Run a native MCP tool and return its text content.
  const callTool = (tool, payload) => {
    const r = spawnSync(HELPERS_NATIVE_CMD, ["call", tool], {
      input: JSON.stringify({ root, ...payload }),
      encoding: "utf8",
      maxBuffer: 64 * 1024 * 1024,
    });
    let parsed;
    try {
      parsed = JSON.parse(r.stdout);
    } catch {
      die(`helpers-native ${tool} failed: ${(r.stderr || r.stdout || "").trim()}`);
    }
    if (parsed.error) die(parsed.error.message);
    return parsed.content.map((c) => c.text).join("\n");
  };
  // Run a native CLI subcommand, streaming its output.
  const runNative = (nativeArgs) => {
    const r = spawnSync(HELPERS_NATIVE_CMD, nativeArgs, { stdio: "inherit" });
    process.exit(r.status || 0);
  };

  switch (sub) {
    case "build":
      console.log(callTool("index_project", {}));
      return;
    case "map":
      console.log(callTool("project_map", {}));
      return;
    case "lookup":
    case "where": {
      const query = args.slice(1).join(" ").trim();
      if (!query) die("usage: helpers index lookup <symbol-or-file>");
      console.log(callTool("lookup", { query }));
      return;
    }
    case "export": {
      const out = args[1] || path.join(root, `${path.basename(root)}.dxbundle`);
      runNative(["bundle", root, out]);
      return;
    }
    case "install": {
      if (!args[1]) die("usage: helpers index install <bundle.dxbundle>");
      runNative(["install", root, args[1]]);
      return;
    }
    case "refs":
    case "list":
      runNative(["refs", root]);
      return;
    default:
      die(`unknown 'helpers index' subcommand: ${sub} (build|map|lookup|export|install|refs)`);
  }
}

