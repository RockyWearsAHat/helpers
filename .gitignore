.DS_Store
# Compiled C shim — platform-specific, built on install from helpers-mcp.c
helpers-mcp
# Native git-cs-grade — platform-specific, built on install from cs-grade/.
# The committed sources are cs-grade/ (Rust) and git-cs-grade.js (Node fallback).
/git-cs-grade
cs-grade/target/
# Native MCP tools — platform-specific, built on install from native/ (Rust).
# Rust-only: no Node fallback. The committed source is the native/ crate.
/helpers-native
native/target/
# Ported git-* CLIs — symlinks to helpers-native, recreated by `helpers build`.
# The committed source is native/src/gitcli/. Keep in sync with GITCLI_NAMES.
/git-resolve
/git-remerge
/git-fucked-the-push
/git-initialize
/git-get
/git-scan-for-leaked-envs
/git-upload
/git-checkpoint
/git-help-i-pushed-an-env
# Generated project index (cheap repo map) — rebuilt on demand by `helpers index`.
# Match at any depth: sub-crates (e.g. native/.helpers/) get their own index cache.
**/.helpers/index/
# Generated build-out plan from `helpers setup` (regenerable; not source).
**/.helpers/SETUP.md
*.dxbundle
build/
coverage/
dist/
vscode-extension/*.vsix
vision-tool/*.vsix
vscode-extension/node_modules/
vision-tool/node_modules/
.vscode/aioserver-vision-ipc.json
.vscode/helpers-vision-ipc.json
.github/session-memory/*
!.github/session-memory/.gitkeep
.env
atlas-api/.env*-chat-history.jsonl
