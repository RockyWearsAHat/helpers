      "severity": "medium",
      "kind": "regex",
      "pattern": "\\.arg\\("
    },
    {
      "rule": "to_digit_is_some",
      "severity": "medium",
      "kind": "regex",
      "pattern": "\\.to_digit\\("
    },
    {
      "rule": "transmute_float_to_int",
      "severity": "medium",
      "kind": "regex",
      "pattern": "\\.to_bits\\("
    },
    {
      "rule": "unimplemented",
      "severity": "low",
      "kind": "regex",
      "pattern": "\\bunimplemented!\\("
    },
    {
      "rule": "uninit_assumed_init",
      "severity": "high",
      "kind": "regex",
      "pattern": "\\.assume_init\\("
    },
    {
      "rule": "uninit_vec",
      "severity": "high",
      "kind": "regex",
      "pattern": "\\.set_len\\("
    },
    {
      "rule": "unnecessary_min_or_max",
      "severity": "medium",
      "kind": "regex",
      "pattern": "\\.min\\("
