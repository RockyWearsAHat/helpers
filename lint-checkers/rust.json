{
  "language": "rust",
  "version": "1.95.0",
  "_note": "Hard rust checker bank, generated + self-validated from clippy docs (each spec flags its rule's exampleBad and not its exampleGood). Version supplements live in rust@<version>.json.",
  "checkers": [
    {
      "rule": "assertions_on_result_states",
      "severity": "low",
      "kind": "regex",
      "pattern": "\\.is_err\\("
    },
    {
      "rule": "big_endian_bytes",
      "severity": "low",
      "kind": "regex",
      "pattern": "\\.to_be_bytes\\("
    },
    {
      "rule": "bind_instead_of_map",
      "severity": "medium",
      "kind": "regex",
      "pattern": "\\.or_else\\("
    },
    {
      "rule": "bool_assert_comparison",
      "severity": "medium",
      "kind": "regex",
      "pattern": "\\bassert_ne!\\("
    },
    {
      "rule": "bytes_count_to_len",
      "severity": "medium",
      "kind": "regex",
      "pattern": "\\.bytes\\("
    },
    {
      "rule": "chars_last_cmp",
      "severity": "medium",
      "kind": "regex",
      "pattern": "\\.chars\\("
    },
    {
      "rule": "clear_with_drain",
      "severity": "low",
      "kind": "regex",
      "pattern": "\\.drain\\("
    },
    {
      "rule": "dbg_macro",
      "severity": "low",
      "kind": "regex",
      "pattern": "\\bdbg!\\("
    },
    {
      "rule": "debug_assert_with_mut_call",
      "severity": "low",
      "kind": "regex",
      "pattern": "\\bdebug_assert_eq!\\("
    },
    {
      "rule": "duration_subsec",
      "severity": "medium",
      "kind": "regex",
      "pattern": "\\.subsec_nanos\\("
    },
    {
      "rule": "eager_transmute",
      "severity": "high",
      "kind": "regex",
      "pattern": "\\.then_some\\("
    },
    {
      "rule": "err_expect",
      "severity": "medium",
      "kind": "regex",
      "pattern": "\\.err\\("
    },
    {
      "rule": "expect_fun_call",
      "severity": "medium",
      "kind": "regex",
      "pattern": "\\.as_str\\("
    },
    {
      "rule": "explicit_deref_methods",
      "severity": "low",
      "kind": "regex",
      "pattern": "\\.deref\\("
    },
    {
      "rule": "extend_with_drain",
      "severity": "medium",
      "kind": "regex",
      "pattern": "\\.extend\\("
