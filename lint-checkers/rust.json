    {
      "rule": "large_include_file",
      "severity": "low",
      "kind": "regex",
      "pattern": "\\binclude_str!\\("
    },
    {
      "rule": "little_endian_bytes",
      "severity": "low",
      "kind": "regex",
      "pattern": "\\.to_le_bytes\\("
    },
    {
      "rule": "manual_c_str_literals",
      "severity": "low",
