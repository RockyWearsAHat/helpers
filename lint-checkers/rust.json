      "severity": "medium",
      "kind": "regex",
      "pattern": "\\.then\\("
    },
    {
      "rule": "filter_map_identity",
      "severity": "medium",
      "kind": "self_binop",
      "ops": [
        "==",
        "!=",
        "&&",
        "||",
        "&",
        "|"
      ]
    },
    {
      "rule": "implicit_clone",
      "severity": "low",
      "kind": "regex",
      "pattern": "\\.to_vec\\("
    },
    {
      "rule": "imprecise_flops",
      "severity": "low",
      "kind": "regex",
      "pattern": "\\.powf\\("
