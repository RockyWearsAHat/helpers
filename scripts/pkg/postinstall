#!/usr/bin/env bash

set -euo pipefail

VSCODE_EXTENSION_DIR="/usr/local/share/github-shell-helpers/vscode"

log() {
	echo "[github-shell-helpers pkg] $1"
}

find_vscode_cli() {
	local user_home="$1"
	local candidate

	for candidate in \
		"$user_home/Applications/Visual Studio Code.app/Contents/Resources/app/bin/code" \
		"/Applications/Visual Studio Code.app/Contents/Resources/app/bin/code" \
		"$user_home/Applications/Visual Studio Code - Insiders.app/Contents/Resources/app/bin/code" \
		"/Applications/Visual Studio Code - Insiders.app/Contents/Resources/app/bin/code"
	do
		if [ -x "$candidate" ]; then
			printf '%s\n' "$candidate"
			return 0
		fi
	done

	return 1
}

run_as_console_user() {
	local user_name="$1"
	shift
	/usr/bin/sudo -H -u "$user_name" -- "$@"
}

remove_mcp_server_for_user() {
	local user_name="$1"
	local user_home="$2"
	local mcp_file="$user_home/Library/Application Support/Code/User/mcp.json"

	[ -f "$mcp_file" ] || return 0

	run_as_console_user "$user_name" /usr/bin/python3 - "$mcp_file" <<'PYEOF'
import json, sys

mcp_path = sys.argv[1]
try:
	with open(mcp_path, "r", encoding="utf-8") as f:
		data = json.load(f)
except (json.JSONDecodeError, FileNotFoundError):
	sys.exit(0)

if "servers" in data and isinstance(data["servers"], dict):
	if "gsh" in data["servers"]:
		del data["servers"]["gsh"]
		with open(mcp_path, "w", encoding="utf-8") as f:
			json.dump(data, f, indent=2)
			f.write("\n")
PYEOF
}

console_user="$(/usr/bin/stat -f%Su /dev/console 2>/dev/null || true)"

if [ -z "$console_user" ] || [ "$console_user" = "root" ] || [ "$console_user" = "loginwindow" ]; then
	log "Skipping VS Code setup because no logged-in console user was detected."
	exit 0
fi

user_home="$(/usr/bin/dscl . -read "/Users/$console_user" NFSHomeDirectory 2>/dev/null | /usr/bin/awk '{print $2}')"
if [ -z "$user_home" ]; then
	user_home="/Users/$console_user"
fi

vscode_user_dir="$user_home/Library/Application Support/Code/User"
run_as_console_user "$console_user" /bin/mkdir -p "$vscode_user_dir/agents" "$vscode_user_dir/prompts"
# Remove legacy mcp.json entry — the VS Code extension now registers the
# gsh MCP server automatically via registerMcpServerDefinitionProvider.
remove_mcp_server_for_user "$console_user" "$user_home"
log "Cleaned legacy gsh entry from mcp.json for $console_user (now extension-managed)."

if code_cli="$(find_vscode_cli "$user_home")"; then
	if run_as_console_user "$console_user" "$code_cli" --install-extension GitHub.copilot --force >/dev/null 2>&1; then
		log "Installed or updated VS Code extension GitHub.copilot for $console_user."
	else
		log "Failed to install VS Code extension GitHub.copilot for $console_user."
	fi

	if run_as_console_user "$console_user" "$code_cli" --install-extension GitHub.copilot-chat --force >/dev/null 2>&1; then
		log "Installed or updated VS Code extension GitHub.copilot-chat for $console_user."
	else
		log "Failed to install VS Code extension GitHub.copilot-chat for $console_user."
	fi

	bundled_vsix="$(find "$VSCODE_EXTENSION_DIR" -maxdepth 1 -name 'git-shell-helpers-*.vsix' -print -quit 2>/dev/null || true)"
	if [ -n "$bundled_vsix" ]; then
		if run_as_console_user "$console_user" "$code_cli" --install-extension "$bundled_vsix" --force >/dev/null 2>&1; then
			log "Installed or updated VS Code extension git-shell-helpers for $console_user."
		else
			log "Failed to install VS Code extension git-shell-helpers for $console_user."
		fi
	else
		log "Bundled git-shell-helpers VS Code extension not found at $VSCODE_EXTENSION_DIR."
	fi
	else
	log "No usable VS Code CLI found for $console_user. Install the Copilot extensions manually if you want VS Code integration."
fi

exit 0