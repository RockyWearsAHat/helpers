# ---------------------------------------------------------------------------
# MCP tools installation
# ---------------------------------------------------------------------------

VSCODE_MCP_JSON="$HOME/Library/Application Support/Code/User/mcp.json"

install_mcp_vision_tool() {
  local dest_dir="${BIN_DIR}/vision-tool"
  local src_dir="${SCRIPT_DIR}/vision-tool"

  if [ ! -d "$src_dir" ]; then
    echo "[install-helpers] WARNING: vision-tool source not found: $src_dir" >&2
    return 1
  fi

  ensure_dir "$dest_dir"
  for f in mcp-server.js extension.js package.json README.md LICENSE.txt; do
    if [ -f "$src_dir/$f" ] && [ "$src_dir/$f" != "$dest_dir/$f" ]; then
      cp "$src_dir/$f" "$dest_dir/$f"
    fi
  done
  echo "[install-helpers] Installed MCP tool: vision-tool -> $dest_dir"
}

maybe_install_vision_extension() {
  local code_cli="$1"
  local ext_dir="${SCRIPT_DIR}/vision-tool"

  if [ ! -d "$ext_dir" ] || [ ! -f "$ext_dir/package.json" ]; then
    return
  fi

  local vsix_file
  vsix_file=$(find "$ext_dir" -maxdepth 1 -name '*.vsix' -print -quit 2>/dev/null)

  if [[ -z "$vsix_file" ]] || [[ "$ext_dir/package.json" -nt "$vsix_file" ]] || [[ "$ext_dir/extension.js" -nt "$vsix_file" ]]; then
    if command -v npx >/dev/null 2>&1; then
      echo "[install-helpers] Building helpers-vision VS Code extension..."
      if (cd "$ext_dir" && npx @vscode/vsce package --no-dependencies --allow-missing-repository) >/dev/null 2>&1; then
        vsix_file=$(find "$ext_dir" -maxdepth 1 -name '*.vsix' -print -quit 2>/dev/null)
      else
        echo "[install-helpers] WARNING: Failed to build helpers-vision extension. Skipping." >&2
        return
      fi
    else
      echo "[install-helpers] npx not found, cannot build helpers-vision extension. Skipping."
      return
    fi
  fi

  if [[ -n "$vsix_file" ]] && [[ -n "$code_cli" ]]; then
    if "$code_cli" --install-extension "$vsix_file" --force >/dev/null 2>&1; then
      echo "[install-helpers] Installed VS Code extension: helpers-vision-tool"
    else
      echo "[install-helpers] WARNING: Failed to install helpers-vision VS Code extension." >&2
    fi
  fi
}

remove_mcp_server() {
  local name="$1"
  local mcp_file="$VSCODE_MCP_JSON"

  [ -f "$mcp_file" ] || return 0

  # Single -c one-liner (no heredoc / multi-line body) per shell-safety; a
  # malformed mcp.json throws and is swallowed by `2>/dev/null || true`.
  python3 -c "import json,sys; p,n=sys.argv[1],sys.argv[2]; d=json.load(open(p)); s=d.get('servers'); (s.pop(n,None), open(p,'w').write(json.dumps(d,indent=2)+chr(10))) if isinstance(s,dict) and n in s else None" "$mcp_file" "$name" 2>/dev/null || true
}

# Purge pre-rebrand static registrations; the current "helpers" server is
# extension-managed and must not be removed here.
remove_legacy_helpers_mcp_servers() {
  remove_mcp_server "gsh"
  remove_mcp_server "git-shell-helpers"
  remove_mcp_server "git-shell-helpers-mcp"
}

configure_mcp_tools() {
  local code_cli="${1:-}"
  local install_research=true
  local install_vision=true

  echo ""
  echo "[install-helpers] MCP Tools (global via Helpers extension)"
  echo "  Bundled tool modules:"
  echo "    1) git-research-mcp  — web search & knowledge cache for Copilot agents"
  echo "    2) helpers-vision        — screenshot analysis with vision models"
  echo ""
  printf '[install-helpers] Install MCP tools into VS Code? [Y/n/pick]: '
  read -r mcp_reply || mcp_reply=""

  if [[ "$mcp_reply" == "n" || "$mcp_reply" == "N" ]]; then
    echo "[install-helpers] Skipped MCP tool installation."
    return
  fi

  if [[ "$mcp_reply" == "pick" || "$mcp_reply" == "p" ]]; then
    printf '  Include research tools (web search, knowledge cache)? [Y/n]: '
    read -r r1 || r1=""
    if [[ "$r1" == "n" || "$r1" == "N" ]]; then
      install_research=false
    fi

    printf '  Include vision tools (screenshot analysis)? [Y/n]: '
    read -r r2 || r2=""
    if [[ "$r2" == "n" || "$r2" == "N" ]]; then
      install_vision=false
    fi
  fi

  # Copy the combined server entry point
  local mcp_src="${SCRIPT_DIR}/helpers-server"
  local mcp_dest="${BIN_DIR}/helpers-server"
  if [ -f "$mcp_src" ] && [ "$mcp_src" != "$mcp_dest" ]; then
    cp "$mcp_src" "$mcp_dest"
  fi

  # Copy vision tool files if selected
  if [ "$install_vision" = true ]; then
    install_mcp_vision_tool
    if [[ -n "$code_cli" ]]; then
      maybe_install_vision_extension "$code_cli"
    fi
  fi

  # Remove legacy static mcp.json entries — the VS Code extension now
  # registers Helpers automatically.
  remove_legacy_helpers_mcp_servers

  echo "[install-helpers] Installed MCP server runtime: ${BIN_DIR}/helpers-server"
  if [ "$install_research" = true ]; then
    echo "  ✓ research tools (web search, knowledge cache, fetch pages)"
  else
    echo "  - research tools left available for later install"
  fi
  if [ "$install_vision" = true ]; then
    echo "  ✓ vision tools (screenshot analysis)"
  else
    echo "  - vision tools not installed"
  fi
  echo "[install-helpers] Helpers is registered by the Helpers VS Code extension."
  echo "[install-helpers] Reload VS Code to refresh MCP server discovery."
}

setup_gpg_signing() {
  if ! command -v gpg >/dev/null 2>&1; then
    echo "[install-helpers] gpg not found — skipping commit signing setup."
    echo "  Install with: brew install gnupg"
    return 0
  fi

  local git_email git_name
  git_email="$(git config --global user.email 2>/dev/null || true)"
  git_name="$(git config --global user.name 2>/dev/null || echo "$USER")"

  if [[ -z "$git_email" ]]; then
    echo "[install-helpers] No git user.email configured — skipping GPG signing setup."
    return 0
  fi

  # Find existing secret key for this email
  local key_id
  key_id="$(gpg --list-secret-keys --keyid-format=long "$git_email" 2>/dev/null \
    | awk '/^sec/{split($2,a,"/"); print a[2]; exit}')"

  if [[ -z "$key_id" ]]; then
    echo "[install-helpers] No GPG key found for $git_email — generating one..."
    gpg --batch --gen-key <<GPGEOF
%no-protection
Key-Type: RSA
Key-Length: 4096
Subkey-Type: RSA
Subkey-Length: 4096
Name-Real: $git_name
Name-Email: $git_email
Expire-Date: 0
GPGEOF
    key_id="$(gpg --list-secret-keys --keyid-format=long "$git_email" 2>/dev/null \
      | awk '/^sec/{split($2,a,"/"); print a[2]; exit}')"
    echo "[install-helpers] GPG key generated: $key_id"
  else
    echo "[install-helpers] Found existing GPG key: $key_id"
  fi

  if [[ -z "$key_id" ]]; then
    echo "[install-helpers] ERROR: Could not determine GPG key ID." >&2
    return 1
  fi

  # Configure git to sign all commits with this key
  git config --global user.signingkey "$key_id"
  git config --global commit.gpgsign true
  echo "[install-helpers] Git configured to sign commits with key $key_id."

  # Upload public key to GitHub
  if ! command -v gh >/dev/null 2>&1; then
    echo "[install-helpers] gh CLI not found — add your GPG public key manually at:"
    echo "  https://github.com/settings/keys"
    return 0
  fi

  if ! gh auth status >/dev/null 2>&1; then
    echo "[install-helpers] Not logged in to GitHub — add your GPG public key manually at:"
    echo "  https://github.com/settings/keys"
    return 0
  fi

  # Ensure write:gpg_key scope — open browser directly instead of device code flow
  if ! gh auth status 2>&1 | grep -qE 'write:gpg_key|admin:gpg_key'; then
    echo "[install-helpers] Requesting write:gpg_key scope from GitHub..."
    gh auth refresh -s write:gpg_key --web
  fi

  # Skip upload if key is already present on GitHub
  if gh gpg-key list 2>/dev/null | grep -qi "$key_id"; then
    echo "[install-helpers] GPG key already on GitHub — commits will show as Verified."
    return 0
  fi

  local tmpfile
  tmpfile="$(mktemp)"
  gpg --armor --export "$key_id" >"$tmpfile"
  if gh gpg-key add "$tmpfile" 2>/dev/null; then
    echo "[install-helpers] GPG public key uploaded to GitHub — commits will now show as Verified."
  else
    echo "[install-helpers] Could not upload GPG key automatically — add it manually at:"
    echo "  https://github.com/settings/keys"
  fi
  rm -f "$tmpfile"
}

setup_vscode_proposed_api() {
  # Enable the chatParticipantPrivate proposed API for our extension.
  # This sets the flag in ~/.vscode/argv.json so VS Code exposes
  # onDidChangeActiveChatPanelSessionResource to our extension.
  local argv_file="$HOME/.vscode/argv.json"
  local ext_id="RockyWearsAHat.helpers"
  local patch_argv_script="${SCRIPT_DIR}/scripts/patch-vscode-argv.js"

  if [ ! -f "$argv_file" ]; then
    echo "[install-helpers] No ~/.vscode/argv.json found — skipping proposed API setup."
    return
  fi

  if grep -q "$ext_id" "$argv_file" 2>/dev/null; then
    echo "[install-helpers] Proposed API already enabled for $ext_id."
    return
  fi

  if [ ! -f "$patch_argv_script" ]; then
    echo "[install-helpers] Proposed API patch helper not found — skipping argv.json update."
    return
  fi

  if command -v node >/dev/null 2>&1 && node "$patch_argv_script" "$argv_file" "$ext_id" >/dev/null 2>&1; then
    echo "[install-helpers] Enabled proposed API for $ext_id in argv.json."
    return
  fi

  echo "[install-helpers] Could not auto-patch argv.json."
  echo "  Add \"$ext_id\" to the enable-proposed-api array in $argv_file manually."
}

apply_vscode_patches() {
  local patch_script="${SCRIPT_DIR}/scripts/patch-vscode-apply-all.js"

  if [ ! -f "$patch_script" ]; then
    echo "[install-helpers] Patch script not found — skipping VS Code patches."
    return
  fi

  if ! command -v node >/dev/null 2>&1; then
    echo "[install-helpers] Node.js not found — cannot apply VS Code patches."
    return
  fi

  local all_patched
  all_patched="$(node "$patch_script" --all-patched 2>/dev/null)" || {
    echo "[install-helpers] Could not check patch status."
    return
  }

  if [ "$all_patched" = "true" ]; then
    echo "[install-helpers] VS Code patches already applied."
    return
  fi

  local missing
  missing="$(node "$patch_script" --missing 2>/dev/null)" || missing="unknown"

  echo ""
  echo "[install-helpers] VS Code Branch Session Patches"
  echo "  Missing patches: $missing"
  echo ""
  echo "  These patches enable seamless branch-per-chat in Copilot:"
  echo "    - folder-switch: removes confirmation dialog on workspace folder swap"
  echo "    - git-head-display: shows worktree branch name in status bar"
  echo ""
  echo "  Patches are non-destructive (originals are backed up) and can be"
  echo "  reverted at any time with: node scripts/patch-vscode-apply-all.js --revert"
  echo ""
  printf '[install-helpers] Apply VS Code patches? [Y/n]: '
  read -r patch_reply || patch_reply=""

  if [[ -z "$patch_reply" || "$patch_reply" == "y" || "$patch_reply" == "Y" ]]; then
    if node "$patch_script" 2>&1 | while IFS= read -r line; do
      echo "  $line"
    done; then
      if node "$patch_script" --check >/dev/null 2>&1; then
        echo "[install-helpers] Patches applied and verified. Quit and restart VS Code (Cmd+Q → reopen) to activate."
      else
        echo "[install-helpers] Patch verification failed. Re-run 'node $patch_script --check' before relying on branch sessions."
      fi
    else
      echo "[install-helpers] Patch application failed. Re-run 'node $patch_script' after resolving the error output above."
    fi
  else
    echo "[install-helpers] Skipped. Apply later with: node scripts/patch-vscode-apply-all.js"
  fi
}

main() {
  echo "[install-helpers] Installing helpers..."

  ensure_dir "$BIN_DIR"
  ensure_dir "$MAN_DIR"

  # git-upload, git-get, git-initialize, git-fucked-the-push, git-remerge,
  # git-resolve, and git-scan-for-leaked-envs are now native Rust (the gitcli
  # module of the helpers-native crate). `helpers build` (run below) compiles the binary
  # and symlinks each CLI name to it — no script copy needed here.
  install_script "git-research-mcp"
  install_script "helpers-server"
  install_script "helpers-server.js"
  install_script "helpers-serverd.js"
  install_script "helpers"

  # Fast C shim source — compiled by `helpers install` (helpers build) into ~/bin/helpers-mcp.
  if [ -f "${SCRIPT_DIR}/helpers-mcp.c" ] && [ "${SCRIPT_DIR}/helpers-mcp.c" != "${BIN_DIR}/helpers-mcp.c" ]; then
    cp "${SCRIPT_DIR}/helpers-mcp.c" "${BIN_DIR}/helpers-mcp.c"
  fi

  # cs-grade source (Rust lib) — the native/ crate depends on it, and git-cs-grade
  # is folded into the one helpers-native binary. Needed only for `--from-source`
  # builds. Copy sources only; never the build target/ artifacts.
  if [ -d "${SCRIPT_DIR}/cs-grade" ] && [ "${SCRIPT_DIR}/cs-grade" != "${BIN_DIR}/cs-grade" ]; then
    mkdir -p "${BIN_DIR}/cs-grade"
    cp "${SCRIPT_DIR}/cs-grade/Cargo.toml" "${BIN_DIR}/cs-grade/" 2>/dev/null || true
    [ -f "${SCRIPT_DIR}/cs-grade/Cargo.lock" ] && cp "${SCRIPT_DIR}/cs-grade/Cargo.lock" "${BIN_DIR}/cs-grade/"
    rm -rf "${BIN_DIR}/cs-grade/src" && cp -R "${SCRIPT_DIR}/cs-grade/src" "${BIN_DIR}/cs-grade/src"
  fi

  # Provision the native tools now: `helpers build` downloads the prebuilt binary
  # for this platform (no toolchain), or builds from source as a fallback.
  if [ -x "${BIN_DIR}/helpers" ]; then
    "${BIN_DIR}/helpers" build || echo "[install-helpers] 'helpers build' reported an issue — run 'helpers doctor'."
  fi

  # Agent config bundle (consumed by `helpers install`). Keep it next to the bins so
  # helpers can resolve it relative to its own location.
  if [ -d "${SCRIPT_DIR}/claude-config" ] && [ "${SCRIPT_DIR}/claude-config" != "${BIN_DIR}/claude-config" ]; then
    rm -rf "${BIN_DIR}/claude-config"
    cp -R "${SCRIPT_DIR}/claude-config" "${BIN_DIR}/claude-config"
    echo "[install-helpers] Installed agent config bundle to ${BIN_DIR}/claude-config"
  fi
  install_support_script "scripts/community-cache-submit.sh" "git-copilot-devops-audit-community-submit"
  install_support_script "scripts/community-cache-pull.sh" "git-copilot-devops-audit-community-pull"
  install_support_script "scripts/community-research-submit.sh" "git-copilot-devops-audit-community-research-submit"
  install_support_script_into_subdir "scripts/patch-vscode-apply-all.js" "scripts/patch-vscode-apply-all.js"
  install_support_script_into_subdir "scripts/patch-vscode-argv.js" "scripts/patch-vscode-argv.js"
  install_support_script_into_subdir "scripts/patch-vscode-folder-switch.js" "scripts/patch-vscode-folder-switch.js"
  install_support_script_into_subdir "scripts/patch-vscode-git-head-display.js" "scripts/patch-vscode-git-head-display.js"
  install_support_script_into_subdir "scripts/patch-vscode-runsubagent-model.js" "scripts/patch-vscode-runsubagent-model.js"

  # Write default git-research-mcp config if it doesn't exist
  local research_config_dir="${HOME}/.config/git-research-mcp"
  local research_env_file="${research_config_dir}/.env"
  if [ ! -f "$research_env_file" ]; then
    ensure_dir "$research_config_dir"
    cat >"$research_env_file" <<'RENV'
# SearXNG — local meta-search instance (Docker container on port 8888).
# Start with: docker run -d --name searxng -p 8888:8080 searxng/searxng:latest
SEARXNG_URL=http://localhost:8888
RENV
    echo "[install-helpers] Wrote default config: $research_env_file"
  fi

  configure_community_cache

  install_man_git_upload
  install_man_git_get
  install_man_git_initialize
  install_man_git_fucked_the_push
  install_man_git_research_mcp

  install_shell_path_setup

  echo ""
  setup_gpg_signing

  # Optional: wire Helpers into Claude Code (MCP server + skills + commands + core).
  if command -v claude >/dev/null 2>&1 || [ -d "${HOME}/.claude" ]; then
    echo ""
    printf '[install-helpers] Install Helpers into Claude Code (MCP server, skills, /helpers command, CLAUDE.md core)? [Y/n]: '
    read -r claude_reply || claude_reply=""
    if [[ -z "$claude_reply" || "$claude_reply" == "y" || "$claude_reply" == "Y" ]]; then
      "${BIN_DIR}/helpers" install --agent claude --force || \
        echo "[install-helpers] Claude install hit an error — run 'helpers install --agent claude' manually."
    else
      echo "[install-helpers] Skipped. Run 'helpers install --agent claude' anytime."
    fi
  fi

  # Optional: install private audit agents and /copilot-devops-audit prompt globally
  # -----------------------------------------------------------------------------
  # HIGHLY RECOMMENDED: Install/Update GitHub Copilot CLI
  # Enables AI commit messages (git upload -ai) and improves Copilot integration
  # -----------------------------------------------------------------------------
  echo ""
  if command -v gh >/dev/null 2>&1; then
    if gh extension list 2>/dev/null | grep -q 'gh-copilot'; then
      printf '[install-helpers] (HIGHLY RECOMMENDED) GitHub Copilot CLI is installed. Update it now? [Y/n]: '
      read -r copilot_reply || copilot_reply=""
      if [[ -z "$copilot_reply" || "$copilot_reply" == "y" || "$copilot_reply" == "Y" ]]; then
        gh extension upgrade gh-copilot && \
          echo "[install-helpers] GitHub Copilot CLI updated." || \
          echo "[install-helpers] Update failed — try: gh extension upgrade gh-copilot"
      fi
    else
      printf '[install-helpers] (HIGHLY RECOMMENDED) Install GitHub Copilot CLI? Enables AI commit messages and better Copilot integration. [Y/n]: '
      read -r copilot_reply || copilot_reply=""
      if [[ -z "$copilot_reply" || "$copilot_reply" == "y" || "$copilot_reply" == "Y" ]]; then
        gh extension install github/gh-copilot && \
          echo "[install-helpers] GitHub Copilot CLI installed. Try: gh copilot suggest" || \
          echo "[install-helpers] Install failed — try manually: gh extension install github/gh-copilot"
      else
        echo "[install-helpers] Skipped. Install later with: gh extension install github/gh-copilot"
      fi
    fi
  else
    echo "[install-helpers] (HIGHLY RECOMMENDED) GitHub CLI (gh) not found."
    echo "  Install it to enable AI commit messages and better Copilot integration:"
    if command -v brew >/dev/null 2>&1; then
      echo "  brew install gh && gh extension install github/gh-copilot"
    else
      echo "  https://cli.github.com  →  then: gh extension install github/gh-copilot"
    fi
  fi

  # Optional: configure VS Code MCP + patches when VS Code is present.
  VSCODE_USER_DIR="$HOME/Library/Application Support/Code/User"
  local code_cli=""
  local should_offer_vscode_setup=false

  if code_cli="$(find_vscode_cli)"; then
    should_offer_vscode_setup=true
    mkdir -p "$VSCODE_USER_DIR"

    echo ""
    maybe_install_vscode_extensions "$code_cli"
  elif [ -d "$VSCODE_USER_DIR" ]; then
    should_offer_vscode_setup=true
    echo ""
    echo "[install-helpers] VS Code user profile found, but no usable 'code' CLI was detected."
    echo "[install-helpers] Install the GitHub Copilot and GitHub Copilot Chat extensions manually for the best experience."
  fi

  if [ "$should_offer_vscode_setup" = true ]; then
    # MCP tools — always offer when VS Code is available
    configure_mcp_tools "$code_cli"

    # Branch-per-chat: proposed API flag + bundle patches
    setup_vscode_proposed_api
    apply_vscode_patches
  fi

  echo ""
  echo "[install-helpers] Done. Open a new terminal to reload PATH and MANPATH changes."
  echo "Then you can use: git upload, git get, git initialize, git fucked-the-push,"
  echo "  helpers setup, and view docs via git help <command>."
}

main "$@"
