# Copy this file to a private local env file, fill in the values you actually have,
# then export it before running:
#   set -a
#   source /path/to/your/release-config.env
#   set +a
#   bash ./scripts/setup-github-release-config.sh
#
# Each ENABLE_* flips on automatically when its credential is filled in, so you
# usually only need to paste the tokens/keys below.

# Recommended GitHub Environment name for release-only credentials.
RELEASE_ENVIRONMENT=release

ENABLE_MACOS_SIGNING=false
ENABLE_NPM_PUBLISH=false
ENABLE_HOMEBREW_PUBLISH=false
ENABLE_AUR_PUBLISH=false
ENABLE_APT_PUBLISH=false
ENABLE_SCOOP_PUBLISH=false

INSTALLER_CERT_BASE64=
INSTALLER_CERT_PASSWORD=
PKG_SIGN_IDENTITY=
NOTARIZE_APPLE_ID=
NOTARIZE_PASSWORD=
NOTARIZE_TEAM_ID=

# npm — an Automation access token from npmjs.com (or `npm token create`).
NPM_TOKEN=

# Homebrew — a GitHub PAT (repo scope) that can push to your tap repo, and the
# tap repo slug (e.g. RockyWearsAHat/homebrew-helpers).
HOMEBREW_TAP_TOKEN=
HOMEBREW_TAP_REPOSITORY=

# AUR — the private half of an SSH key whose public half is on your AUR account.
AUR_SSH_PRIVATE_KEY=
AUR_PACKAGE_NAME=helpers

# apt — ASCII-armored GPG private key used to sign the apt repo. Export with:
#   gpg --armor --export-secret-keys <KEYID>
# Paste it as a single value (multi-line is fine inside quotes when sourcing).
APT_GPG_PRIVATE_KEY=

# Scoop — a GitHub PAT (repo scope) that can push to your bucket repo, and the
# bucket repo slug (e.g. RockyWearsAHat/scoop-helpers). The manifest lands in
# bucket/helpers.json so users run: scoop bucket add helpers <repo-url>.
SCOOP_BUCKET_TOKEN=
SCOOP_BUCKET_REPOSITORY=
